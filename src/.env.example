SMTP_HOST=smtp.gol.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM_EMAIL=no-reply@isgrtech.com
MAIL_FROM_NAME=お問い合わせフォーム
SMTP_ENVELOPE_FROM=isgrtech-info@gol.com
MAIL_TO=isgrtech-info@gol.com

# Cloudflare Turnstile（本番では実際のサイトキー/シークレットキーに差し替える）
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# 連投とみなす間隔（秒）
SUBMIT_INTERVAL_SECONDS=10

# ── アプリ設定 ─────────────────────────────────────────────
# Cloudflare Tunnel で公開する場合は https://xxx.example.com 形式で指定
CLIENT_URL=https://contact.isgrtech.com

# ホストに公開するポート番号（デフォルト: 8081）
HOST_PORT=8081
